export default async function handler(req, res) {
  if (req.method !== "POST") return res.status(405).end();

  const { mensagem } = req.body; 

  const prompt = `
    Atue como um extrator de dados financeiros para o app Finanças PRO AI.
    Analise a frase: "${mensagem}"
    Responda APENAS um objeto JSON com:
    {
      "valor": número,
      "descricao": "string curta",
      "tipo": "receita" ou "despesa",
      "categoria": "Alimentação", "Transporte", "Lazer", "Essencial" ou "Investimento",
      "regra": "50", "30" ou "20"
    }
    Regras de Categoria:
    - Mercado, Aluguel, Contas, Saúde = Essencial (50)
    - Restaurantes, Cinema, Jogos, Streaming = Lazer (30)
    - Aportes, Poupança, Ações = Investimento (20)
    - Ganhos, Salário, Pix recebido = tipo "receita" e regra "0"
  `;

  try {
    const response = await fetch(
      "https://generativelanguage.googleapis.com/v1/models/gemini-1.5-flash:generateContent",
      {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "x-goog-api-key": process.env.GEMINI_API_KEY
        },
        body: JSON.stringify({
          contents: [{ parts: [{ text: prompt }] }],
          generationConfig: { response_mime_type: "application/json" }
        })
      }
    );

    const data = await response.json();
    const objetoFinanceiro = JSON.parse(data.candidates[0].content.parts[0].text);

    // IMPORTANTE: Aqui você deve chamar sua lógica de salvar no banco (ex: salvar no dados.json)
    // Para este exemplo, estamos devolvendo o objeto para o front-end salvar
    res.status(200).json(objetoFinanceiro);

  } catch (err) {
    res.status(500).json({ erro: "Erro ao processar com IA" });
  }
}
